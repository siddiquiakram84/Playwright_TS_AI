{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@aut/*":       ["aut/*"],
      "@core/*":      ["core/*"],
      "@pages/*":     ["aut/pages/*"],
      "@api/*":       ["aut/api/*"],
      "@utils/*":     ["core/utils/*"],
      "@fixtures/*":  ["core/fixtures/*"],
      "@test-data/*": ["aut/test-data/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "allure-results", "allure-report", "playwright-report"]
}
