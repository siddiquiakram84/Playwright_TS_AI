        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-playwright" },
          "query": "from(bucket: \"testresults\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"test_run\")\n  |> filter(fn: (r) => r._field == \"skipped\")\n  |> sum()"
        }
