      "title": "AVG DURATION",
      "gridPos": { "h": 4, "w": 3, "x": 16, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-playwright" },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 30000 },
              { "color": "#F2495C", "value": 60000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-playwright" },
          "query": "from(bucket: \"testresults\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"test_run\")\n  |> filter(fn: (r) => r._field == \"duration\")\n  |> mean()"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "FLAKY TESTS",
      "gridPos": { "h": 4, "w": 4, "x": 19, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-playwright" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
