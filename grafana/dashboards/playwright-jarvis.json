          "unit": "ms",
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg_duration" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "basic" }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#73BF69", "value": null },
                    { "color": "#FF9830", "value": 5000 },
                    { "color": "#F2495C", "value": 15000 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-playwright" },
          "query": "from(bucket: \"testresults\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"test_case\")\n  |> filter(fn: (r) => r._field == \"duration\")\n  |> group(columns: [\"title\", \"project\", \"suite\"])\n  |> mean()\n  |> rename(columns: {_value: \"avg_duration\"})\n  |> sort(columns: [\"avg_duration\"], desc: true)\n  |> limit(n: 20)"
        }
      ]
    }

  ]
}
