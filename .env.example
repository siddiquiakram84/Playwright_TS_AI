# ─────────────────────────────────────────────────────────────────────────────
# Playwright TS AI Framework — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Environment: dev | test | prod
ENV=test

# ── Application Under Test — active environment URLs ─────────────────────────
# These override the per-env defaults in core/utils/envConfig.ts.
# Usually you only set the env-specific vars below instead of these.
UI_BASE_URL=https://automationexercise.com
API_BASE_URL=https://fakestoreapi.com

# Per-environment URL overrides (set the pair for your target environment)
# Leave blank to use the hardcoded defaults in envConfig.ts URL_MATRIX.
# DEV_UI_URL=http://localhost:3000
# DEV_API_URL=http://localhost:4000
# TEST_UI_URL=https://automationexercise.com
# TEST_API_URL=https://fakestoreapi.com
# STAGING_UI_URL=https://staging.automationexercise.com
# STAGING_API_URL=https://staging-api.fakestoreapi.com
# PROD_UI_URL=https://automationexercise.com
# PROD_API_URL=https://fakestoreapi.com

# ── Test Credentials (sensitive — never commit real values) ───────────────────
# UI tests
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=Test@1234

# API tests — FakeStoreAPI default demo account
# Override with your environment's credentials
API_USERNAME=johnd
API_PASSWORD=m38rmF$

# ── Timeouts (ms) ─────────────────────────────────────────────────────────────
DEFAULT_TIMEOUT=30000
API_TIMEOUT=15000
AI_TIMEOUT=600000

# ── Allure ────────────────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=dashboard/allure/results

# ── InfluxDB (optional — metrics push) ───────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=mytoken
INFLUXDB_ORG=playwright
INFLUXDB_BUCKET=testresults

# ── JARVIS Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────
# GEN AI SUPERPOWERS
# ─────────────────────────────────────────────────────────────────────────────
# AI_PROVIDER controls which LLM backend powers all AI features.
#
# Option 1 — Local / FREE (default): Ollama runs models on your machine.
#   Install Ollama: https://ollama.com/download
#   Pull a model:   ollama pull llama3.2:3b    (small, fast, ~2 GB)
#                   ollama pull moondream       (vision — visual regression)
#
# Option 2 — Anthropic Claude (paid, better quality):
#   Set AI_PROVIDER=anthropic and add your ANTHROPIC_API_KEY below.
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=local

# Ollama settings (used when AI_PROVIDER=local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=moondream

# Anthropic Claude (used when AI_PROVIDER=anthropic)
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AI OPS DASHBOARD
# Live dashboard: LLM call log, self-healing log, test gen stages, recorder.
# Start: npm run ai:ops  OR  setup.bat → option 26
# URL: http://localhost:9093
# ─────────────────────────────────────────────────────────────────────────────
AI_OPS_PORT=9093

# Admin password for the ⚙ Admin panel (provider/key management)
# Change this before using in a shared/company environment.
ADMIN_SECRET=changeme

# ─────────────────────────────────────────────────────────────────────────────
# LANGSMITH TRACING (optional — free tier available)
# Traces every LLM call to the LangSmith UI for inspection and debugging.
#
# 1. Sign up free:  https://smith.langchain.com
# 2. Create an API key in Settings → API Keys
# 3. Set LANGCHAIN_TRACING_V2=true and paste your key below.
# ─────────────────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=playwright-ai-framework
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─────────────────────────────────────────────────────────────────────────────
# VECTOR MEMORY / RAG (Retrieval-Augmented Generation)
# Feeds the local codebase into a vector store so the LLM gets relevant
# context (existing specs, POMs, fixtures) when generating new tests.
#
# Step 1 — Pull the embedding model (274 MB, one-time):
#   ollama pull nomic-embed-text
#
# Step 2 — Index the codebase:
#   npm run ai:index
#
# Step 3 — Generate tests with RAG context:
#   npm run ai:generate-tests -- --nl "test product search"
#   (RAG context is injected automatically — no extra flags needed)
#
# The vector index is stored at core/ai/memory/.index/codebase.json
# Re-run `npm run ai:index` after adding new specs or POMs.
# ─────────────────────────────────────────────────────────────────────────────

# Embedding model via Ollama (free, local, 768 dims — best for code retrieval)
OLLAMA_EMBED_MODEL=nomic-embed-text
