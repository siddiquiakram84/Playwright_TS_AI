# Environment: dev | test | prod
ENV=test

# UI Base URLs
UI_BASE_URL=https://automationexercise.com

# API Base URLs
API_BASE_URL=https://fakestoreapi.com

# Test credentials (override per environment)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=Test@1234

# Timeouts (ms)
DEFAULT_TIMEOUT=30000
API_TIMEOUT=15000

# Allure
ALLURE_RESULTS_DIR=dashboard/allure/results

# InfluxDB (metrics — requires monitoring stack)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=mytoken
INFLUXDB_ORG=playwright
INFLUXDB_BUCKET=testresults

# JARVIS Dashboard
DASHBOARD_PORT=9090
