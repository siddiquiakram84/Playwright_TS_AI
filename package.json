{
  "name": "playwright-ts-ai-framework",
  "version": "2.0.0",
  "description": "Enterprise-grade Playwright + TypeScript E2E automation framework with JARVIS dashboard",
  "private": true,
  "scripts": {
    "test":              "playwright test",
    "test:ui":           "playwright test --project=ui",
    "test:api":          "playwright test --project=api",
    "test:hybrid":       "playwright test --project=hybrid",
    "test:headed":       "playwright test --headed --project=ui",
    "test:debug":        "playwright test --debug",
    "test:firefox":      "playwright test --project=ui-firefox",
    "test:webkit":       "playwright test --project=ui-webkit",
    "test:edge":         "playwright test --project=ui-edge",
    "test:browsers":     "playwright test --project=ui --project=ui-firefox --project=ui-webkit --project=ui-edge",
    "allure:generate":   "allure generate dashboard/allure/results --clean -o dashboard/allure/report",
    "allure:open":       "allure open dashboard/allure/report",
    "allure:serve":      "allure serve dashboard/allure/results",
    "report":            "playwright show-report dashboard/playwright/report",
    "metrics:push":      "tsx core/scripts/push-metrics.ts",
    "dashboard":         "node dashboard/jarvis/server.js",
    "type-check":        "tsc --noEmit",
    "clean":             "rimraf dashboard/allure/results dashboard/allure/report dashboard/playwright/report dashboard/playwright/test-results logs"
  },
  "dependencies": {
    "ajv":                         "^8.17.1",
    "ajv-formats":                 "^3.0.1",
    "dotenv":                      "^16.4.5",
    "winston":                     "^3.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node":      "^22.9.0",
    "allure-playwright":"^3.0.4",
    "rimraf":           "^6.0.1",
    "tsx":              "^4.19.2",
    "typescript":       "^5.6.3"
  },
  "optionalDependencies": {
    "@influxdata/influxdb-client": "^1.35.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
