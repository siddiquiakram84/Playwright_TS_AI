{
  "name": "playwright-ts-ai-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright + TypeScript E2E automation framework",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:hybrid": "playwright test --project=hybrid",
    "test:headed": "playwright test --headed --project=ui",
    "test:debug": "playwright test --debug",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "playwright show-report",
    "lint": "eslint 'src/**/*.ts' --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.9.0",
    "allure-playwright": "^3.0.4",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
